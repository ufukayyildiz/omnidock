{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "emailfox",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "vars": {
    // Optional. Leave empty for workers.dev. Set to a custom dashboard host such as "mail.example.com".
    "MANAGEMENT_HOST": "",
    // Optional. Leave empty when the API token can access exactly one Cloudflare account.
    "CLOUDFLARE_ACCOUNT_ID": "",
    // Optional. Verified sender address for password reset emails. Defaults to the admin email.
    "PASSWORD_RESET_FROM": "",
    "WORKER_SCRIPT_NAME": "emailfox"
  },
  "d1_databases": [
    {
      "binding": "DB",
      // Public template: leave database_id out so first-time Deploy to Cloudflare can provision it.
      // Installed copies should keep the generated database_id for updates.
      "database_name": "emailfox-db",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MAIL_BUCKET",
      "bucket_name": "emailfox-mail"
    }
  ],
  "send_email": [
    {
      "name": "EMAIL"
    }
  ]
}
